{
  "$schema": "https://raw.githubusercontent.com/DavidAnson/markdownlint/main/schema/markdownlint-config-schema.json",
  "default": true,
  "MD003": {
    "style": "atx"
  },
  "MD004": {
    "style": "dash"
  },
  "MD007": {
    "indent": 2
  },
  "MD013": false,
  "MD024": {
    "siblings_only": true
  },
  "MD025": {
    "front_matter_title": ""
  },
  "MD033": {
    "allowed_elements": [
      "details",
      "summary",
      "sup",
      "sub",
      "br",
      "img",
      "kbd",
      "div",
      "span"
    ]
  },
  "MD034": false,
  "MD041": false
}
